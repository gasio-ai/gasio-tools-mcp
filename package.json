  "author": "Gasio Tools",
  "license": "MIT",
  "homepage": "https://tools.gasio.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/kimhoecheon-cmd/gasio-tools-site.git",
    "directory": "gasio-mcp-server"
  },
  "bugs": {
    "url": "https://github.com/kimhoecheon-cmd/gasio-tools-site/issues"
  },
  "type": "module",
